@startuml
title File Upload Process - RecallAI

actor User as U
participant "React Frontend" as FE
participant "Backend API" as API
participant "Reource Usage Service" as RUS
participant "Postgres DB" as DB
participant "RabbitMQ" as MQ
participant "Async Handler" as Handler
participant "Embedding Service" as ES
participant "Qdrant DB" as QD
participant "Open AI" as OA

activate U
U -> FE : Selects and uploads file
activate FE
FE -> API : POST /upload (file, metadata)
activate API
API -> API : Validate File
API -> RUS : Check Resources Usage Request
activate RUS
RUS -> DB : Check Resources Usage
activate DB
DB --> RUS : Resources limit not reached
RUS --> API : Response
deactivate RUS
API -> DB : Store file in DB and mark status as 'Uploaded'
deactivate DB
API -> MQ : Publish File Upload Event
activate MQ
API --> FE : 201 Created (Upload successful)
deactivate API
deactivate FE

== Async Processing ==
MQ -> Handler : Delivers 'File Uploaded' event
deactivate MQ
activate Handler
Handler -> DB : Fetch file and mark status as 'Processing'
activate DB
DB --> Handler : File
Handler -> Handler : Clean and chunk file content
Handler -> ES : Request embedding of chunks
activate ES
ES -> OA : Embed chunks
activate OA
OA --> ES : Embedded chunks
deactivate OA
ES -> RUS : Update resource usage
activate RUS
RUS -> DB: Update Resource Usage
deactivate RUS
ES --> Handler : Embedded chunks
deactivate ES
Handler -> QD : Create collection if non-existent
activate QD
Handler -> QD : Store embeddings
deactivate QD
Handler -> DB : Mark status as 'Processed'
deactivate Handler
deactivate DB

== Fetching Status ==
U -> FE : Refresh
activate FE
FE -> API : GET /filesSummary
activate API
API -> DB : Get files
activate DB
DB --> API : Files
deactivate DB
API --> FE : Files Summary with latest status
deactivate API
deactivate FE
@enduml